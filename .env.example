# SQL local
DB_USER=sa
DB_PASS=__REQUIRED__
DB_SERVER=localhost
DB_NAME=MailDB
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# SQL remotas opcionales (panel)
PROD_DB_USER=
PROD_DB_PASS=
PROD_DB_SERVER=
PROD_DB_NAME=

TEST_DB_USER=
TEST_DB_PASS=
TEST_DB_SERVER=
TEST_DB_NAME=

# SMTP (modo simple)
SMTP_USER=__REQUIRED__
SMTP_PASS=__REQUIRED__
SMTP_HOST=__REQUIRED__
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FROM=
SMTP_DEFAULT_ACCOUNT=default

# SMTP avanzado (opcional): JSON de cuentas/perfiles
# SMTP_ACCOUNTS_JSON={"default":{"host":"smtp.example.com","port":465,"secure":true,"auth":{"user":"u","pass":"p"},"fromEmail":"no-reply@example.com"}}
# SENDER_PROFILE_MAP_JSON={"default":"default","informes":"default"}

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Worker/Dispatcher
DISPATCHER_POLL_MS=5000
DISPATCHER_BATCH_SIZE=50
MAIL_LOCK_MINUTES=15
MAIL_MAX_RETRIES=5
WORKER_CONCURRENCY=5

# Alertas
TG_TOKEN=
TG_CHAT=

# Panel web
PANEL_USER=__REQUIRED__
PANEL_PASS=__REQUIRED__
